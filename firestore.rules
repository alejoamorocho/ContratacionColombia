rules_version = '2';

// El sitio público es 100% estático y NO usa Firestore.
// Esta regla deny-all es defensa en profundidad: si por error se asocia una
// base Firestore a este proyecto, nadie puede leer ni escribir nada.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
